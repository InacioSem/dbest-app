# Demo Mode — set to "true" to use mock data without API keys
USE_DEMO_MODE=true

# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://localhost:5432/dbest_app

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Storage (Cloudflare R2 or AWS S3)
STORAGE_PROVIDER=local
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# API Keys (not needed when USE_DEMO_MODE=true)
EVOLINK_API_KEY=
EVOLINK_BASE_URL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
FAL_API_KEY=
GEMINI_API_KEY=
HEYGEN_API_KEY=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_DEFAULT_LOCALE=en
